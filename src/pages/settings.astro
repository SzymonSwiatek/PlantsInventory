---
import Layout from "@/layouts/Layout.astro";
import NavBar from "@/components/NavBar.astro";
import { createClient } from "@/lib/supabase";
import ReminderToggle from "@/components/settings/ReminderToggle";

const supabase = createClient(Astro.request.headers, Astro.cookies);

const { data: prefRow } = supabase
  ? await supabase.from("user_preferences").select("reminders_enabled").maybeSingle()
  : { data: null };

const remindersEnabled = prefRow?.reminders_enabled ?? true;
---

<Layout title="Settings">
  <div class="bg-cosmic min-h-screen px-4 pt-4 pb-24 text-white sm:p-4">
    <div class="mx-auto w-full max-w-2xl py-10">
      <NavBar active="settings" />
      <header class="mb-8">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Settings
        </h1>
        <p class="mt-1 text-sm text-blue-100/60">Manage your notification preferences</p>
      </header>

      <section class="rounded-2xl border border-white/10 bg-white/5 px-6 py-5">
        <h2 class="mb-4 text-sm font-semibold tracking-wider text-blue-100/60 uppercase">Reminders</h2>
        <ReminderToggle remindersEnabled={remindersEnabled} client:load />
      </section>
    </div>
  </div>
</Layout>
