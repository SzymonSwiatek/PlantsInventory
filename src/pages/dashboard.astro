---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import LocationActions from "@/components/locations/LocationActions";

const { user } = Astro.locals;
const error = Astro.url.searchParams.get("error");

const supabase = createClient(Astro.request.headers, Astro.cookies);
const { data: locations } = supabase
  ? await supabase.from("locations").select("id, name, plants(count)").order("created_at", { ascending: true })
  : { data: null };
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto w-full max-w-2xl py-10">
      <header class="mb-8 flex items-center justify-between gap-4">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
            Your locations
          </h1>
          <p class="mt-1 text-sm text-blue-100/60">{user?.email}</p>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="/today"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Today's care
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
            >
              Sign out
            </button>
          </form>
        </div>
      </header>

      {
        error && (
          <p class="mb-6 rounded-lg border border-red-400/30 bg-red-500/10 px-4 py-3 text-sm text-red-100">{error}</p>
        )
      }

      <form
        method="POST"
        action="/api/locations"
        class="mb-8 flex gap-3 rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-xl"
      >
        <input
          type="text"
          name="name"
          required
          maxlength="100"
          placeholder="Add a location (e.g. Living room)"
          class="flex-1 rounded-lg border border-white/20 bg-white/5 px-3 py-2 text-sm placeholder:text-blue-100/40 focus:border-white/40 focus:outline-none"
        />
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium transition-colors hover:bg-white/20"
        >
          Add
        </button>
      </form>

      {
        locations && locations.length > 0 ? (
          <ul class="space-y-3">
            {locations.map((loc) => {
              const count = loc.plants[0]?.count ?? 0;
              return (
                <li class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/10 px-5 py-4 backdrop-blur-xl transition-colors hover:bg-white/20">
                  <a href={`/locations/${loc.id}`} class="flex flex-1 items-center gap-3 self-stretch">
                    <span class="font-medium">{loc.name}</span>
                    <span class="text-sm text-blue-100/40">{count === 1 ? "1 plant" : `${count} plants`}</span>
                  </a>
                  <LocationActions client:load id={loc.id} name={loc.name} plantCount={count} />
                </li>
              );
            })}
          </ul>
        ) : (
          <div class="rounded-2xl border border-dashed border-white/15 bg-white/5 p-8 text-center text-sm text-blue-100/60">
            No locations yet. Add your first one above to start cataloging plants.
          </div>
        )
      }
    </div>
  </div>
</Layout>
