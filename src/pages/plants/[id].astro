---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { signedPhotoUrl } from "@/lib/storage";
import type { Plant, AiSuggestion } from "@/types";

const id = Astro.params.id;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let plant: Plant | null = null;
let photoUrl: string | null = null;

if (id && supabase) {
  const { data } = await supabase
    .from("plants")
    .select(
      "id, name, species, description, sunlight, note, watering_interval_days, winterization_cutoff, photo_path, ai_suggestion, location_id, user_id, created_at, updated_at, last_watered_at, next_water_due_at, water_snooze_until, winterized_at",
    )
    .eq("id", id)
    .maybeSingle();
  plant = data;

  if (plant?.photo_path) {
    photoUrl = await signedPhotoUrl(supabase, plant.photo_path);
  }
}

if (!plant) {
  Astro.response.status = 404;
}

const aiSuggestion = plant?.ai_suggestion as AiSuggestion | null;

const aiSpecies = aiSuggestion?.species ?? null;
const aiDescription = aiSuggestion?.description ?? null;
const aiSunlight = aiSuggestion?.sunlight ?? null;
const aiWateringDays = aiSuggestion?.watering_interval_days ?? null;
const aiWinterizationCutoff = aiSuggestion?.winterization_cutoff ?? null;
---

<Layout title={plant?.name ?? "Plant not found"}>
  <div class="bg-cosmic min-h-screen p-4 text-white">
    {
      plant ? (
        <div class="mx-auto w-full max-w-2xl py-10">
          <header class="mb-8">
            <a
              href={`/locations/${plant.location_id}`}
              class="text-sm text-blue-100/50 transition-colors hover:text-blue-100/80"
            >
              ← Back to location
            </a>
            <h1 class="mt-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
              {plant.name}
            </h1>
          </header>

          {photoUrl ? (
            <div class="mb-8">
              <img src={photoUrl} alt={plant.name} class="h-64 w-full rounded-2xl object-cover" />
            </div>
          ) : (
            <div class="mb-8 flex h-64 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-4xl text-blue-100/30">
              🌱
            </div>
          )}

          <div class="space-y-4">
            <div class="space-y-5 rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
              <div>
                <p class="mb-1 text-xs font-medium tracking-wider text-blue-100/50 uppercase">Name</p>
                <p class="font-medium">{plant.name}</p>
              </div>

              <div>
                <p class="mb-1 text-xs font-medium tracking-wider text-blue-100/50 uppercase">Species</p>
                <p class="font-medium">{plant.species ?? <span class="text-blue-100/40 italic">—</span>}</p>
                {aiSpecies && <p class="mt-1 text-xs text-blue-100/40 italic">AI suggested: {aiSpecies}</p>}
              </div>

              <div>
                <p class="mb-1 text-xs font-medium tracking-wider text-blue-100/50 uppercase">Description</p>
                <p class="text-sm leading-relaxed">
                  {plant.description ?? <span class="text-blue-100/40 italic">—</span>}
                </p>
                {aiDescription && <p class="mt-1 text-xs text-blue-100/40 italic">AI suggested: {aiDescription}</p>}
              </div>

              <div>
                <p class="mb-1 text-xs font-medium tracking-wider text-blue-100/50 uppercase">Sunlight</p>
                <p class="font-medium">{plant.sunlight ?? <span class="text-blue-100/40 italic">—</span>}</p>
                {aiSunlight && <p class="mt-1 text-xs text-blue-100/40 italic">AI suggested: {aiSunlight}</p>}
              </div>

              <div>
                <p class="mb-1 text-xs font-medium tracking-wider text-blue-100/50 uppercase">Watering interval</p>
                <p class="font-medium">
                  {plant.watering_interval_days !== null ? (
                    `Every ${plant.watering_interval_days} day${plant.watering_interval_days === 1 ? "" : "s"}`
                  ) : (
                    <span class="text-blue-100/40 italic">—</span>
                  )}
                </p>
                {aiWateringDays !== null && (
                  <p class="mt-1 text-xs text-blue-100/40 italic">
                    AI suggested: every {aiWateringDays} day{aiWateringDays === 1 ? "" : "s"}
                  </p>
                )}
              </div>

              <div>
                <p class="mb-1 text-xs font-medium tracking-wider text-blue-100/50 uppercase">Winterization cutoff</p>
                <p class="font-medium">
                  {plant.winterization_cutoff ?? <span class="text-blue-100/40 italic">No winterization needed</span>}
                </p>
                {aiWinterizationCutoff && (
                  <p class="mt-1 text-xs text-blue-100/40 italic">AI suggested: {aiWinterizationCutoff}</p>
                )}
              </div>

              <div>
                <p class="mb-1 text-xs font-medium tracking-wider text-blue-100/50 uppercase">Note</p>
                <p class="text-sm leading-relaxed whitespace-pre-wrap">
                  {plant.note ?? <span class="text-blue-100/40 italic">—</span>}
                </p>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <div class="flex min-h-screen items-center justify-center">
          <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center backdrop-blur-xl">
            <h1 class="mb-2 text-xl font-bold">Plant not found</h1>
            <p class="mb-6 text-sm text-blue-100/60">It may have been removed, or it isn't yours.</p>
            <a
              href="/dashboard"
              class="inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
            >
              Back to locations
            </a>
          </div>
        </div>
      )
    }
  </div>
</Layout>
