---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { signedPhotoUrl } from "@/lib/storage";
import type { Plant } from "@/types";
import PlantDetail from "@/components/plants/PlantDetail";

const id = Astro.params.id;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let plant: Plant | null = null;
let photoUrl: string | null = null;
let locations: { id: string; name: string }[] = [];

if (id && supabase) {
  const [plantResult, locationsResult] = await Promise.all([
    supabase
      .from("plants")
      .select(
        "id, name, species, description, sunlight, note, watering_interval_days, winterization_cutoff, photo_path, ai_suggestion, location_id, user_id, created_at, updated_at, last_watered_at, next_water_due_at, water_snooze_until, winterized_at",
      )
      .eq("id", id)
      .maybeSingle(),
    supabase.from("locations").select("id, name").order("name"),
  ]);

  plant = plantResult.data;
  locations = locationsResult.data ?? [];

  if (plant?.photo_path) {
    photoUrl = await signedPhotoUrl(supabase, plant.photo_path);
  }
}

if (!plant) {
  Astro.response.status = 404;
}
---

<Layout title={plant?.name ?? "Plant not found"}>
  <div class="bg-cosmic min-h-screen p-4 text-white">
    {
      plant ? (
        <div class="mx-auto w-full max-w-2xl py-10">
          <header class="mb-8">
            <a
              href={`/locations/${plant.location_id}`}
              class="text-sm text-blue-100/50 transition-colors hover:text-blue-100/80"
            >
              ← Back to location
            </a>
            <h1 class="mt-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
              {plant.name}
            </h1>
          </header>

          <PlantDetail client:load plant={plant} locations={locations} photoUrl={photoUrl} />
        </div>
      ) : (
        <div class="flex min-h-screen items-center justify-center">
          <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center backdrop-blur-xl">
            <h1 class="mb-2 text-xl font-bold">Plant not found</h1>
            <p class="mb-6 text-sm text-blue-100/60">It may have been removed, or it isn't yours.</p>
            <a
              href="/dashboard"
              class="inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
            >
              Back to locations
            </a>
          </div>
        </div>
      )
    }
  </div>
</Layout>
