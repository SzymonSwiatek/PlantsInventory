---
import Layout from "@/layouts/Layout.astro";
import NavBar from "@/components/NavBar.astro";
import { createClient } from "@/lib/supabase";
import TodayList from "@/components/today/TodayList";
import type { TodayPlant, TodayWinterPlant } from "@/types";

const supabase = createClient(Astro.request.headers, Astro.cookies);

const now = new Date().toISOString();
const { data: rows, error: waterError } = supabase
  ? await supabase
      .from("plants")
      .select("id, name, next_water_due_at, locations(name)")
      .not("next_water_due_at", "is", null)
      .lte("next_water_due_at", now)
      .or(`water_snooze_until.is.null,water_snooze_until.lte.${now}`)
      .order("next_water_due_at", { ascending: true })
  : { data: null, error: null };

const { data: winterRows, error: winterError } = supabase
  ? await supabase
      .from("winterization_due_plants")
      .select("id, name, location_name, winterization_cutoff, this_year_cutoff")
      .order("this_year_cutoff", { ascending: true })
  : { data: null, error: null };

// A failed query must not be conflated with "nothing due" — surface a degraded
// banner instead of silently rendering the empty state.
const loadError = Boolean(waterError ?? winterError);

interface PlantRow {
  id: string;
  name: string;
  next_water_due_at: string | null;
  locations: { name: string } | null;
}

interface WinterPlantRow {
  id: string;
  name: string;
  location_name: string | null;
  winterization_cutoff: string | null;
  this_year_cutoff: string | null;
}

const nowMs = Date.now();
const plants: TodayPlant[] = ((rows ?? []) as PlantRow[]).map((row) => {
  const dueMs = new Date(row.next_water_due_at ?? now).getTime();
  const daysOverdue = Math.max(0, Math.floor((nowMs - dueMs) / (1000 * 60 * 60 * 24)));
  return {
    id: row.id,
    name: row.name,
    locationName: row.locations?.name ?? "Unknown location",
    daysOverdue,
  };
});

const winterPlants: TodayWinterPlant[] = ((winterRows ?? []) as WinterPlantRow[]).map((row) => ({
  id: row.id,
  name: row.name,
  locationName: row.location_name ?? "Unknown location",
  cutoff: row.winterization_cutoff ?? "",
}));
---

<Layout title="Today's Care">
  <div class="bg-cosmic min-h-screen px-4 pt-4 pb-24 text-white sm:p-4">
    <div class="mx-auto w-full max-w-2xl py-10">
      <NavBar active="today" />
      <header class="mb-8">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Today's care
        </h1>
        <p class="mt-1 text-sm text-blue-100/60">Plants due for watering</p>
      </header>

      {
        loadError && (
          <div
            role="alert"
            class="mb-6 rounded-lg border border-amber-400/30 bg-amber-400/10 px-4 py-3 text-sm text-amber-100"
          >
            We couldn't load some of your reminders right now. This list may be incomplete — please refresh in a moment.
          </div>
        )
      }

      <TodayList plants={plants} winterPlants={winterPlants} client:load />
    </div>
  </div>
</Layout>
