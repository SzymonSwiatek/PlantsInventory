---
import Layout from "@/layouts/Layout.astro";
import SignInForm from "@/components/auth/SignInForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign in">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <div class="mb-6 flex flex-col items-center gap-3 text-center">
        <span
          class="flex size-14 items-center justify-center rounded-2xl border border-white/10 bg-white/10 text-3xl shadow-lg"
          aria-hidden="true"
        >
          🌱
        </span>
        <span class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-xl font-bold text-transparent">
          Plants Inventory
        </span>
      </div>
      <h1 class="mb-2 text-center text-2xl font-bold text-white">Sign in</h1>
      <p class="mb-6 text-center text-sm text-blue-100/60">
        No password needed — enter your email and we'll send you a magic link to sign in.
      </p>
      <SignInForm serverError={error} client:load />
    </div>
  </div>
</Layout>
