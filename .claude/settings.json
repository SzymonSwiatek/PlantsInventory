{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix . --quiet",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "f=$(jq -r \".tool_input.file_path // empty\"); case \"$f\" in *.ts|*.tsx) npx tsc --noEmit;; esac",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "AI_AGENT=1 bash -c 'FILE=$(jq -r .tool_input.file_path) && npx vitest related \"$FILE\" --run'",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}